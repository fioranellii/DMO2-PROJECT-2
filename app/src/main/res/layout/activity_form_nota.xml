<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/etTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Título do dia..."
        android:textSize="22sp"
        android:textStyle="bold"
        android:importantForAutofill="no"
        android:inputType="textCapSentences"
        android:minHeight="48dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:fillViewport="true">

        <EditText
            android:id="@+id/etConteudo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Como foi o seu dia? Escreva aqui ou use o microfone..."
            android:gravity="top"
            android:importantForAutofill="no"
            android:inputType="textMultiLine|textCapSentences"
            android:background="@android:color/transparent"
            android:textSize="16sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnMicrofone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="🎙️ Ditar por Voz"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnSalvar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Salvar Entrada no Diário"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>